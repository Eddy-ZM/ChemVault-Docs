---
import logo from '../assets/chemvault-logo-mark.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Page Not Found | ChemVault</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f5f7fb;
        color: #172033;
      }

      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        padding: 32px;
      }

      main {
        width: min(680px, 100%);
      }

      img {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        display: block;
        margin-bottom: 28px;
      }

      h1 {
        margin: 0 0 12px;
        font-size: clamp(2.25rem, 7vw, 4.5rem);
        line-height: 0.95;
        letter-spacing: 0;
      }

      p {
        margin: 0 0 28px;
        max-width: 58ch;
        color: #526071;
        font-size: 1.05rem;
        line-height: 1.7;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      a {
        display: inline-flex;
        align-items: center;
        min-height: 42px;
        padding: 0 16px;
        border: 1px solid #cbd6e5;
        border-radius: 8px;
        color: #0f62d4;
        background: #ffffff;
        text-decoration: none;
        font-weight: 750;
      }

      a:focus-visible,
      a:hover {
        border-color: #0f62d4;
        background: #eef5ff;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          background: #111827;
          color: #f7f9fd;
        }

        p {
          color: #aab6c6;
        }

        a {
          border-color: #334155;
          color: #8ec5ff;
          background: #172033;
        }

        a:focus-visible,
        a:hover {
          border-color: #8ec5ff;
          background: #1f2a3d;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <img src={logo.src} width="512" height="512" alt="ChemVault" />
      <h1>Page not found</h1>
      <p>
        The ChemVault Docs page you requested does not exist or has moved. Use the manual,
        product map, or link index to find the current entry.
      </p>
      <nav aria-label="Helpful links">
        <a href="/manual/">Manual</a>
        <a href="/manual/product-map/">Product Map</a>
        <a href="/manual/links/">Related Links</a>
      </nav>
    </main>
  </body>
</html>
